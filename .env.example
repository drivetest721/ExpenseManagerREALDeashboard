# ────────────────────────────────────────────────────────────────
# Backend environment template
# Copy to `.env` and fill real values. NEVER commit `.env`.
# ────────────────────────────────────────────────────────────────

APP_NAME=ExpenseManager
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=expense_manager

# JWT
JWT_SECRET_KEY=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# SMTP (optional until Phase 12)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Limits
ATTACHMENT_MAX_BYTES=10485760

# SLA defaults (business days)
SLA_APPROVAL_DAYS=3
SLA_QUERY_RESPONSE_DAYS=2
